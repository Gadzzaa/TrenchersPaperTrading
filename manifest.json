
{
  "name": "TrenchersPaperTrading",
  "description": "An application to simulate paper trading.",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "notifications"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "Images/logo.png"
  },
  "host_permissions": [
    "https://axiom.trade/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://axiom.trade/*"],
      "js": ["Scripts/inject.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dashboard.html",
        "Sounds/*.wav"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "Images/16x16.png",
    "48": "Images/48x48.png",
    "128": "Images/128x128.png"
  }
}
